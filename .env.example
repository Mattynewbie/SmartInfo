# Expo public values are bundled into the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional AI-compatible text proxy. Keep provider secrets on the server.
EXPO_PUBLIC_AI_PROXY_URL=https://your-api.example.com/companion-answer

# Demo admin unlock code for local/prototype UI access.
# For production, use Supabase Auth + admin RLS policies instead of a public client code.
EXPO_PUBLIC_ADMIN_ACCESS_CODE=change-this-demo-admin-code

# Required for real signup verification: configure SMTP inside Supabase Dashboard
# Authentication > Emails > SMTP Settings. Never put SMTP passwords in Expo public env.

# Optional Supabase Edge Function URL for deployed ElevenLabs STT/TTS proxy.
# In local Expo development, the app falls back to http://127.0.0.1:8787.
EXPO_PUBLIC_VOICE_PROXY_URL=https://your-project.functions.supabase.co/elevenlabs-voice

# Free-tier local STT option for development. Groq is used for speech-to-text.
STT_PROVIDER=groq
GROQ_API_KEY=server-side-only
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_LANGUAGE=tl
GROQ_STT_PROMPT=Tagalog-English public assistance questions from schools, government offices, and public places.

# AI answers when no saved FAQ/public info matches.
# groq/compound can use Groq's built-in tools such as web search.
GROQ_CHAT_MODEL=groq/compound
GROQ_CHAT_FALLBACK_MODEL=groq/compound-mini

# Do not expose this in Expo client code. Set it as a Supabase Edge Function secret:
# supabase secrets set ELEVENLABS_API_KEY=your-rotated-elevenlabs-key
ELEVENLABS_API_KEY=server-side-only
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
